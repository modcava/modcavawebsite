# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=mocava_db
MYSQL_USER=mocava_user
MYSQL_PASSWORD=mocava_pass

# Two databases on the same MySQL server. Switch which one the app uses
# by setting DB_ENV below. Prisma CLI commands have :prod / :test variants
# in package.json (e.g. `npm run db:push:test`).
DATABASE_URL_PROD="mysql://mocava_user:mocava_pass@localhost:3306/mocava_db"
DATABASE_URL_TEST="mysql://mocava_user:mocava_pass@localhost:3306/mocava_db_test"

# Which DB the running app connects to. "prod" or "test".
DB_ENV=prod

# Legacy fallback — read by Prisma CLI if you run raw `prisma db push`
# (without using the :prod/:test npm scripts). Keep in sync with the
# DB_ENV-selected URL above.
DATABASE_URL="${DATABASE_URL_PROD}"

# ── NextAuth ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Modcava

# ── Google Drive Image Picker (optional) ───────────────────
# สร้างที่ Google Cloud Console → APIs & Services → Credentials
# 1. Picker API Key  (API Key — restrict to "Google Picker API")
# 2. OAuth 2.0 Client ID (Web application — ใส่ Authorized JS origins: http://localhost:3000)
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Discord Notifications ──────────────────────────────────
# Webhook URL สำหรับแจ้งเตือน admin เมื่อมีออเดอร์ใหม่
DISCORD_ORDER_WEBHOOK_URL=
